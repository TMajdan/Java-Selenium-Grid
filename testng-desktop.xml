<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="desktop-suite" verbose="2" parallel="methods" thread-count="2" configfailurepolicy="continue" data-provider-thread-count="2">

    <listeners>
        <listener class-name="general.listeners.TestListener" />
        <listener class-name="general.listeners.AllureListener" />
        <listener class-name="general.listeners.RetryListener" />
    </listeners>

    <test name="Desktop Tests">
        <packages>
            <package name="tests.desktop.*" />
        </packages>
    </test>
</suite>