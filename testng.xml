<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!--
  ===========================================================================
  Selenium Grid Automation Framework - TestNG Suite Configuration
  ===========================================================================
  Usage:
    mvn clean test                                              # default (qa, chrome)
    mvn clean test -Denvironment=stage -Dbrowser=firefox        # custom env + browser
    mvn clean test -DsuiteXmlFile=testng-grid.xml               # Selenium Grid mode
    mvn clean test -Dgroups=smoke                               # only smoke tests
    mvn clean test -Dexecution.threadCount=8                    # parallel threads
  ===========================================================================
-->
<suite name="Selenium Grid Automation Suite"
       verbose="2"
       parallel="methods"
       thread-count="4"
       configfailurepolicy="continue"
       data-provider-thread-count="2"
       object-factory="org.testng.internal.objectfactory.DefaultObjectFactory">

    <!-- ================================================================== -->
    <!-- Suite-level parameters (can be overridden via -D or Maven profiles) -->
    <!-- ================================================================== -->
    <parameter name="environment" value="qa" />
    <parameter name="browser" value="CHROME" />
    <parameter name="executionMode" value="LOCAL" />
    <parameter name="headless" value="false" />

    <!-- ================================================================== -->
    <!-- Global Listeners                                                    -->
    <!-- ================================================================== -->
    <listeners>
        <listener class-name="main.listeners.TestListener" />
        <listener class-name="main.listeners.AllureListener" />
        <listener class-name="main.listeners.RetryListener" />
        <listener class-name="main.listeners.ExtentReporter" />
    </listeners>

    <!-- ================================================================== -->
    <!-- Groups: Smoke Tests – szybka weryfikacja krytycznych funkcji        -->
    <!-- ================================================================== -->
    <test name="Smoke Tests" parallel="methods" thread-count="4">
        <parameter name="browser" value="CHROME" />
        <groups>
            <run>
                <include name="smoke" />
            </run>
        </groups>
        <packages>
            <package name="main.test.tests.*" />
        </packages>
    </test>

    <!-- ================================================================== -->
    <!-- Groups: Regression Tests – pełna weryfikacja                        -->
    <!-- ================================================================== -->
    <test name="Regression Tests - Chrome" parallel="methods" thread-count="4">
        <parameter name="browser" value="CHROME" />
        <groups>
            <run>
                <include name="regression" />
                <include name="login" />
                <include name="search" />
            </run>
        </groups>
        <packages>
            <package name="main.test.tests.*" />
        </packages>
    </test>

    <!-- ================================================================== -->
    <!-- Cross-browser: Firefox                                              -->
    <!-- ================================================================== -->
    <test name="Cross-Browser - Firefox" parallel="methods" thread-count="2">
        <parameter name="browser" value="FIREFOX" />
        <packages>
            <package name="main.test.tests.*" />
        </packages>
    </test>

    <!-- ================================================================== -->
    <!-- Cross-browser: Edge                                                -->
    <!-- ================================================================== -->
    <test name="Cross-Browser - Edge" parallel="methods" thread-count="2">
        <parameter name="browser" value="EDGE" />
        <packages>
            <package name="main.test.tests.*" />
        </packages>
    </test>

    <!-- ================================================================== -->
    <!-- Flaky Tests z osobnym retry count                                   -->
    <!-- ================================================================== -->
    <test name="Flaky Tests" parallel="methods" thread-count="2">
        <parameter name="browser" value="CHROME" />
        <groups>
            <run>
                <include name="flaky" />
            </run>
        </groups>
        <packages>
            <package name="main.test.tests.*" />
        </packages>
    </test>

</suite>
